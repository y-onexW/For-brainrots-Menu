local placeId = game.PlaceId

if placeId == 136919941417380 then
    print("Running in the correct game!")
    loadstring(game:HttpGet("https://raw.githubusercontent.com/y-onexW/For-brainrots-Menu/refs/heads/main/BikeForBrainrots.luau"))()

elseif placeId == 114640202062357 then
    print("Running in the correct game!")
    loadstring(game:HttpGet("https://raw.githubusercontent.com/y-onexW/For-brainrots-Menu/refs/heads/main/SwingForBrainRots.luau"))()

else
    warn("This script does not support this game ID: " .. tostring(placeId))
end